        </mxCell>
        <mxCell id="aRe8IIhhsic-ApcYbnX7-7" value="集合A和集合B的差集(集合A - 集合B)&lt;br&gt;取存在于集合A中但不存在于集合B中的列&lt;br&gt;记为集合A_MINUS_B" style="rounded=0;whiteSpace=wrap;html=1;align=left;" parent="1" vertex="1">
          <mxGeometry x="20" y="-30" width="230" height="80" as="geometry" />
        </mxCell>
        <mxCell id="00pz0sp0omp9TNyprszB-1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" parent="1" source="aRe8IIhhsic-ApcYbnX7-9" target="aRe8IIhhsic-ApcYbnX7-20" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="aRe8IIhhsic-ApcYbnX7-9" value="集合A和集合B的交集(集合A&amp;nbsp;∩集合B)&lt;br&gt;取同时存在于集合A和集合B中的列&lt;br&gt;记为A_INTER_B" style="rounded=0;whiteSpace=wrap;html=1;align=left;" parent="1" vertex="1">
